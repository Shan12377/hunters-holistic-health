    {
      "id": "d1f08001-0000-4000-8000-000000000003",
      "name": "Compute Session Actions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 0],
      "parameters": {
        "jsCode": "const out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  if (!j['Session ID'] || !j['Session Date']) continue;\n  const time = j['Session Time'] || '09:00';\n  const sessionAt = new Date(`${j['Session Date']}T${time}:00`);\n  if (isNaN(sessionAt.getTime())) continue;\n  const hoursUntil = (sessionAt.getTime() - Date.now()) / 3600000;\n  let action = 'none';\n  if (hoursUntil > 23 && hoursUntil <= 25 && j['Reminder Sent'] !== 'YES') {\n    action = 'send_reminder';\n  } else if (hoursUntil > 0 && hoursUntil <= 2.5 && j['Intake Submitted'] === 'YES' && j['Brief Sent'] !== 'YES') {\n    action = 'generate_brief';\n  }\n  if (action !== 'none') {\n    out.push({ json: { ...j, action, hoursUntil: Math.round(hoursUntil * 10) / 10 } });\n  }\n}\nreturn out;"
      }
    },
    {
      "id": "d1f08001-0000-4000-8000-000000000004",
      "name": "Route Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [660, 0],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "typeValidation": "loose",
                  "leftValue": ""
                },
                "combinator": "and",
                "conditions": [
                  {
                    "id": "w1",
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "send_reminder",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "send_reminder"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "typeValidation": "loose",
                  "leftValue": ""
                },
                "combinator": "and",
                "conditions": [
                  {
                    "id": "w2",
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "generate_brief",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "generate_brief"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "d1f08001-0000-4000-8000-000000000005",
      "name": "Send Intake Reminder",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [880, -150],
      "parameters": {
        "sendTo": "={{ $json['Client Email'] }}",
        "subject": "Your session tomorrow, please take 5 minutes",
        "emailType": "text",
        "message": "=Hi,\n\nYour session with Hunter's Holistic Health is scheduled for {{ $json['Session Date'] }} at {{ $json['Session Time'] }}.\n\nPlease take 5 minutes to complete this short pre-session form so we can make the most of your time:\n\n[REPLACE_WITH_INTAKE_FORM_URL]\n\nYour Session ID is {{ $json['Session ID'] }}. You will need it on the form.\n\nPrivacy notice: please do not include lab results, diagnoses, or medication details in this form. Those belong in your secure clinical channel. This form covers your current concerns and the questions you want answered.\n\nSee you soon,\nHunter's Holistic Health",
        "options": {}
      },
      "credentials": {
        "gmailOAuth2": {
          "id": "[REPLACE_WITH_YOUR_CREDENTIAL]",
          "name": "Gmail [REPLACE_WITH_YOUR_CREDENTIAL]"
        }
