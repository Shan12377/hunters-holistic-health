          "mode": "list",
          "cachedResultName": "gpt-4o-mini"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You generate a structured pre-session brief for a functional medicine educator. Input is a client's short pre-session intake. Output sections, in order: 1) Chief Concern (one or two sentences). 2) Reported Changes Since Last Session. 3) Client Questions To Address (as stated, lightly cleaned up). 4) Suggested Session Priorities (3 bullets max, educational framing only).\n\nRules: refer to the session by Session ID and client code only. Never invent a client name. Do not diagnose, do not suggest medication changes, do not interpret labs. Keep it under 250 words. Do not use the em dash character anywhere in your output."
            },
            {
              "role": "user",
              "content": "=Session ID: {{ $json['Session ID'] }}\nClient Code: {{ $json['Client Code'] }}\nSession Type: {{ $json['Session Type'] }}\nVisit Reason: {{ $json['Visit Reason'] }}\nCurrent Concerns: {{ $json['Current Concerns'] }}\nQuestions for Today: {{ $json['Questions for Today'] }}\nChanges Since Last Session: {{ $json['Changes Since Last Session'] }}"
            }
          ]
        },
        "options": {}
      },
